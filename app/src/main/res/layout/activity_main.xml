<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- ============= LOGIN SCREEN ============= -->
    <LinearLayout
        android:id="@+id/loginScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="40dp"
        android:visibility="visible">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SUICIDE"
            android:textColor="#ffffff"
            android:textSize="32sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif"
            android:letterSpacing="0.15"
            android:textAlignment="center" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SQUAD"
            android:textColor="#cc0000"
            android:textSize="32sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif"
            android:letterSpacing="0.15"
            android:layout_marginBottom="40dp"
            android:textAlignment="center" />

        <!-- Input username -->
        <EditText
            android:id="@+id/usernameInput"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginBottom="16dp"
            android:background="@drawable/bg_input"
            android:fontFamily="monospace"
            android:gravity="center_vertical"
            android:hint="username"
            android:inputType="text"
            android:paddingHorizontal="16dp"
            android:textColor="#f0f0f0"
            android:textColorHint="#660000"
            android:textSize="14sp" />

        <!-- Input password -->
        <EditText
            android:id="@+id/passwordInput"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/bg_input"
            android:fontFamily="monospace"
            android:gravity="center_vertical"
            android:hint="password"
            android:inputType="textPassword"
            android:paddingHorizontal="16dp"
            android:textColor="#f0f0f0"
            android:textColorHint="#660000"
            android:textSize="14sp" />

        <!-- Login button -->
        <Button
            android:id="@+id/loginBtn"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_btn"
            android:fontFamily="monospace"
            android:text="// LOGIN"
            android:textColor="#000000"
            android:textSize="13sp"
            android:textStyle="bold"
            android:letterSpacing="0.2"
            android:stateListAnimator="@null" />

        <!-- Login error -->
        <TextView
            android:id="@+id/loginError"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textColor="#ff1a1a"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:visibility="gone" />

    </LinearLayout>

    <!-- ============= DASHBOARD SCREEN ============= -->
    <LinearLayout
        android:id="@+id/dashboardScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#000000"
        android:visibility="gone">

        <!-- Top bar -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:background="#000000"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/loggedUser"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginStart="20dp"
                android:text=""
                android:textColor="#bb3333"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.1" />

            <TextView
                android:id="@+id/logoutBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="20dp"
                android:text="// EXIT"
                android:textColor="#660000"
                android:textSize="11sp"
                android:fontFamily="monospace"
                android:letterSpacing="0.15" />

        </RelativeLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#330000" />

        <!-- Dashboard content -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="4dp"
                    android:text="// squad_panel.exe"
                    android:textColor="#cc0000"
                    android:textSize="10sp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.25"
                    android:textAllCaps="true" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="28dp"
                    android:text="Command Center"
                    android:textColor="#ffffff"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif" />

                <!-- Row 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:id="@+id/btnHome"
                        android:layout_width="0dp"
                        android:layout_height="90dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:background="@drawable/bg_card"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="&#9760;"
                            android:textColor="#cc0000"
                            android:textSize="24sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="HOME"
                            android:textColor="#f0f0f0"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace"
                            android:letterSpacing="0.3" />

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/btnTargets"
                        android:layout_width="0dp"
                        android:layout_height="90dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:background="@drawable/bg_card"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="&#127919;"
                            android:textColor="#cc0000"
                            android:textSize="24sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="TARGETS"
                            android:textColor="#f0f0f0"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace"
                            android:letterSpacing="0.3" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Row 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="12dp">

                    <LinearLayout
                        android:id="@+id/btnTools"
                        android:layout_width="0dp"
                        android:layout_height="90dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:background="@drawable/bg_card"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="&#9881;"
                            android:textColor="#cc0000"
                            android:textSize="24sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="TOOLS"
                            android:textColor="#f0f0f0"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace"
                            android:letterSpacing="0.3" />

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/btnTerminal"
                        android:layout_width="0dp"
                        android:layout_height="90dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:background="@drawable/bg_card"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="&#9889;"
                            android:textColor="#cc0000"
                            android:textSize="24sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="TERMINAL"
                            android:textColor="#f0f0f0"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace"
                            android:letterSpacing="0.3" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Admin Panel card -->
                <LinearLayout
                    android:id="@+id/btnAdmin"
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:background="@drawable/bg_card_accent"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="&#9760; ADMIN PANEL"
                        android:textColor="#cc0000"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:fontFamily="monospace"
                        android:letterSpacing="0.3" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:text="// quick actions"
                    android:textColor="#cc0000"
                    android:textSize="9sp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.25"
                    android:textAllCaps="true" />

                <!-- Add User -->
                <LinearLayout
                    android:id="@+id/btnAddUser"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_card"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginBottom="8dp"
                    android:paddingHorizontal="20dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="&#128101;  Add User"
                        android:textColor="#f0f0f0"
                        android:textSize="12sp"
                        android:fontFamily="monospace" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="&#9654;"
                        android:textColor="#660000"
                        android:textSize="14sp" />

                </LinearLayout>

                <!-- Add Tool -->
                <LinearLayout
                    android:id="@+id/btnAddTool"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_card"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginBottom="8dp"
                    android:paddingHorizontal="20dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="&#9881;  Add Tool"
                        android:textColor="#f0f0f0"
                        android:textSize="12sp"
                        android:fontFamily="monospace" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="&#9654;"
                        android:textColor="#660000"
                        android:textSize="14sp" />

                </LinearLayout>

                <!-- Add Target -->
                <LinearLayout
                    android:id="@+id/btnAddTarget"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_card"
                    android:clickable="true"
                    android:focusable="true"
                    android:layout_marginBottom="12dp"
                    android:paddingHorizontal="20dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="&#127919;  Add Target"
                        android:textColor="#f0f0f0"
                        android:textSize="12sp"
                        android:fontFamily="monospace" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="&#9654;"
                        android:textColor="#660000"
                        android:textSize="14sp" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="// EVIL CORP // HACK DIVISION"
                    android:textColor="#330000"
                    android:textSize="9sp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.15"
                    android:layout_gravity="center" />

            </LinearLayout>
        </ScrollView>

    </LinearLayout>

    <!-- ============= WEBVIEW SCREEN ============= -->
    <LinearLayout
        android:id="@+id/webScreen"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#000000"
        android:visibility="gone">

        <!-- WebView nav bar -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="#000000"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/webBackBtn"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_centerVertical="true"
                android:layout_marginStart="8dp"
                android:background="?android:selectableItemBackgroundBorderless"
                android:scaleType="center"
                android:src="@drawable/ic_back" />

            <TextView
                android:id="@+id/webTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="#f0f0f0"
                android:textSize="11sp"
                android:fontFamily="monospace" />

            <ImageButton
                android:id="@+id/webRefreshBtn"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="8dp"
                android:background="?android:selectableItemBackgroundBorderless"
                android:scaleType="center"
                android:src="@drawable/ic_refresh" />

        </RelativeLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#330000" />

        <!-- Progress bar -->
        <ProgressBar
            android:id="@+id/webProgress"
            style="?android:progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:progressTint="#cc0000"
            android:visibility="gone" />

        <WebView
            android:id="@+id/webView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

    </LinearLayout>

</FrameLayout>
